# ─── Torn City Bookie Analyzer Bot v4 — Environment Variables ────────────────
# LOCAL:   copy to .env, fill in values, leave WEBHOOK_URL blank
# RAILWAY: set all of these in Railway dashboard → Variables tab

# ── Required ──────────────────────────────────────────────────────────────────

# 1. Telegram bot token — from https://t.me/BotFather → /newbot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 2. Anthropic API key — from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 3. The Odds API key — from https://the-odds-api.com/ (free: 500 req/month)
#    Covers all Torn Bookie sports: NFL, NBA, NHL, MLB, EPL, Tennis, Rugby,
#    Cricket, CS2, Dota2, League of Legends, and more.
ODDS_API_KEY=your_odds_api_key_here

# ── Real-Time Scanner ─────────────────────────────────────────────────────────

# 4. Your Telegram user or group ID — message @userinfobot to find yours.
#    Scanner alerts are pushed here. If left blank, /watchstart uses the
#    chat that invoked the command.
CHAT_ID=

# 5. How often the scanner cycles, in seconds. Default: 1800 (30 min).
#    Minimum recommended: 300 (5 min) — lower burns your free API quota fast.
SCAN_INTERVAL=1800

# 6. Minimum confidence tier to trigger a push alert.
#    Options: HIGH | MEDIUM | LOW
#    HIGH = fewest alerts, highest signal quality (recommended)
#    MEDIUM = includes moderate picks too
#    LOW = alerts on everything Claude picks
ALERT_MIN_CONF=HIGH

# ── Railway Deployment ────────────────────────────────────────────────────────

# 7. Your Railway public domain — set AFTER first deploy.
#    Example: https://torn-bookie-bot-production.up.railway.app
#    Leave blank for local polling mode.
WEBHOOK_URL=

# PORT is injected by Railway automatically. Do NOT set it manually on Railway.
# For local webhook testing only:
# PORT=8080

# 8. SQLite database file path (default: bets.db in working directory)
#    On Railway, the working directory is ephemeral — use a volume or leave default.
DB_PATH=bets.db
